# ============================================================
#  Constructora Edwin — variables de entorno (plantilla)
#  Copia este archivo a `.env.local` y rellena los valores.
#  `.env.local` está en .gitignore — NUNCA lo subas al repo.
# ============================================================

# --- Público (seguro para el navegador) ---
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-publica"

# --- Secreto (SOLO servidor — jamás expuesto al navegador) ---
# Esta llave otorga acceso total. Se usa únicamente en código server-only.
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-secreta"

# Nombre de la app (opcional)
NEXT_PUBLIC_APP_NAME="Constructora Edwin"
